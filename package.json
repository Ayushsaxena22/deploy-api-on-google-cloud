{
  "name": "nestjs-microservices-product-api",
  "version": "1.0.0",
  "description": "NestJS microservice CRUD API for products using TCP transport.",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "ts-node-dev --respawn --transpile-only --project tsconfig.json src/main.ts",
    "tcp:client": "node scripts/tcp-client.js",
    "postinstall": "npm run build",
    "start:prod": "node dist/main"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.9",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.9",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/microservices": "^10.4.9",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/platform-express": "^10.4.22",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "mongoose": "^8.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@types/node": "^18.18.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
